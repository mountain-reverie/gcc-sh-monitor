TIME   = @CSiBE-TIME@
SIZE  := @CSiBE-SIZE@
CC     = @CSiBE-CC@
LD     = @CSiBE-CCLD@
AR     = @CSiBE-AR@
CCOPT := @CSiBE-CCOPT@
ZIP   := @CSiBE-ZIP@
VPATH := @CSiBE-SRCDIR@

CFLAGS = $(CCOPT) $(TEEMDEFS) -w
LDFLAGS = -lm
EXTLIBS = ../ell/libell.a ../nrrd/libnrrd.a ../biff/libbiff.a ../hest/libhest.a ../air/libair.a
LIBS = liblimn.a $(EXTLIBS)

OBJS = defaultsLimn.o qn.o light.o env.o cam.o methodsLimn.o obj.o io.o \
	hestLimn.o transform.o renderLimn.o shapes.o \
	splineMisc.o splineMethods.o splineEval.o
TESTS = test/map test/light test/tcam test/tps test/tspline test/tbc \
	test/tcamanim test/soid
TOBJS = $(addsuffix .o,$(TESTS))

PROGS:=$(TESTS)

all:

.c.o:
	I=@CSiBE-OBJCOUNTER@ ; \
	while [ $$((I--)) -gt 0 ] ; do \
		$(CC) $(CFLAGS) -o $@ $< ; \
	done

dirs:
	mkdir -p test

objs: dirs $(OBJS) $(TOBJS)

prgs: $(PROGS)

comp: dirs $(PROGS)
	for X in $^ ; do \
		$(ZIP) <$$X >$$X.zipped ; \
		ls -l $$X.zipped >$$X.comp ; \
	done

# PROG

$(PROGS):
	$(LD) $(LDFLAGS) -o $@ $^

# RUN

@CSiBE-RUN-RULES@

# --

liblimn.a: $(OBJS)
	$(AR) $@ $^

$(EXTLIBS):
	$(MAKE) -C $(dir $@) $(notdir $@)

test/map: test/map.o $(LIBS)
test/light: test/light.o $(LIBS)
test/tcam: test/tcam.o $(LIBS)
test/tps: test/tps.o $(LIBS)
test/tspline: test/tspline.o $(LIBS)
test/tbc: test/tbc.o $(LIBS)
test/tcamanim: test/tcamanim.o $(LIBS)
test/soid: test/soid.o $(LIBS)

clean-comp:
	for X in $(PROGS) ; do \
		rm -f $$X.zipped $$X.comp ; \
	done

clean: clean-comp
	rm -f $(OBJS) $(TOBJS) $(PROGS) liblimn.a
