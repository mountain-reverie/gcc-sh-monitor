TIME   = @CSiBE-TIME@
SIZE  := @CSiBE-SIZE@
CC     = @CSiBE-CC@
LD     = @CSiBE-CCLD@
AR     = @CSiBE-AR@
CCOPT := @CSiBE-CCOPT@
ZIP   := @CSiBE-ZIP@
VPATH := @CSiBE-SRCDIR@

CFLAGS = $(CCOPT) $(TEEMDEFS) -w

OBJS = defaultsGage.o miscGage.o shape.o pvl.o ctx.o update.o filter.o \
	print.o scl.o sclanswer.o sclprint.o sclfilter.o \
	vecGage.o vecprint.o st.o

all:

.c.o:
	I=@CSiBE-OBJCOUNTER@ ; \
	while [ $$((I--)) -gt 0 ] ; do \
		$(CC) $(CFLAGS) -o $@ $< ; \
	done

objs: $(OBJS)

prgs:

comp:

# PROG

# RUN

@CSiBE-RUN-RULES@

# --

libgage.a: $(OBJS)
	$(AR) $@ $^

clean-comp:

clean:
	rm -f $(OBJS) libgage.a
