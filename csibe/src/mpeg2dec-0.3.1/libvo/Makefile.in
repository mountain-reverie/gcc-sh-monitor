TIME   = @CSiBE-TIME@
SIZE  := @CSiBE-SIZE@
CC     = @CSiBE-CC@
LD     = @CSiBE-CCLD@
AR     = @CSiBE-AR@
CCOPT := @CSiBE-CCOPT@
ZIP   := @CSiBE-ZIP@
VPATH := @CSiBE-SRCDIR@

OBJS = video_out.o video_out_x11.o video_out_dx.o video_out_sdl.o \
       video_out_null.o video_out_pgm.o \
       yuv2rgb.o yuv2rgb_mlib.o yuv2rgb_mmx.o

CFLAGS = $(CCOPT) -I$(VPATH) -I$(VPATH)/../include -I$(VPATH)/../../include  -I. -I../include -I../../include -w

all:

.c.o:
	I=@CSiBE-OBJCOUNTER@ ; \
	while [ $$((I--)) -gt 0 ] ; do \
		$(CC) $(CFLAGS) -o $@ $< ; \
	done

objs: $(OBJS)

prgs:

comp:

# RUN

@CSiBE-RUN-RULES@

# --

libvo.a: $(OBJS)
	$(AR) $@ $^

clean-comp:

clean:
	rm -f $(OBJS) libvo.a
