static void
tcp_timeout(void *data)
{



  sys_timeout(5000, tcp_timeout, ((void *)0) );
}
 
static void
tcpip_init_done(void *arg)
{
  sys_sem_t *sem;
  sem = arg;
  sys_sem_signal(*sem);
}
 
static void
main_thread(void *arg)
{
  struct ip_addr ipaddr, netmask, gw;
  sys_sem_t sem;

    
  ( &gw )->addr = htonl(((u32_t)(  192  & 0xff) << 24) | ((u32_t)( 168  & 0xff) << 16) | ((u32_t)( 1  & 0xff) << 8) | (u32_t)( 1  & 0xff)) ;
  ( &ipaddr )->addr = htonl(((u32_t)(  192  & 0xff) << 24) | ((u32_t)( 168  & 0xff) << 16) | ((u32_t)( 1  & 0xff) << 8) | (u32_t)( 2  & 0xff)) ;
  ( &netmask )->addr = htonl(((u32_t)(  255  & 0xff) << 24) | ((u32_t)( 255  & 0xff) << 16) | ((u32_t)( 255  & 0xff) << 8) | (u32_t)( 0  & 0xff)) ;

  netif_set_default(netif_add(&ipaddr, &netmask, &gw, unixif_init_client,
			      tcpip_input));
   


  
  sem = sys_sem_new(0);
  tcpip_init(tcpip_init_done, &sem);
  sys_sem_wait(sem);
  sys_sem_free(sem);
  printf("TCP/IP initialized.\n");

  tcpecho_init();
