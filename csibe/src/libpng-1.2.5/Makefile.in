TIME   = @CSiBE-TIME@
SIZE  := @CSiBE-SIZE@
CC     = @CSiBE-CC@
LD     = @CSiBE-CCLD@
AR     = @CSiBE-AR@
CCOPT := @CSiBE-CCOPT@
ZIP   := @CSiBE-ZIP@
RUNSIM:= @CSiBE-RUNSIM@
VPATH := @CSiBE-SRCDIR@

##Requires zlib and mathlib

CFLAGS=$(CCOPT) -I. -I$(VPATH)/../include/zlib -w
LDFLAGS=-lm -lz

OBJS = png.o pngset.o pngget.o pngrutil.o pngtrans.o pngwutil.o \
	pngread.o pngrio.o pngwio.o pngwrite.o pngrtran.o \
	pngwtran.o pngmem.o pngerror.o pngpread.o

PROGS=pngtest png2pnm pnm2png

all:

.c.o:
	I=@CSiBE-OBJCOUNTER@ ; \
	while [ $$((I--)) -gt 0 ] ; do \
		$(CC) $(CFLAGS) -o $@ $< ; \
	done

objs: $(OBJS) pngtest.o png2pnm.o pnm2png.o

prgs: $(PROGS)

comp: $(PROGS)
	for X in $^ ; do \
		$(ZIP) <$$X >$$X.zipped ; \
		ls -l $$X.zipped >$$X.comp ; \
	done

# PROG

pngtest: pngtest.o $(OBJS)
	$(LD) $(CFLAGS) -o $@ $^ $(LDFLAGS)

png2pnm: png2pnm.o $(OBJS)
	$(LD) $(CFLAGS) -o $@ $^ $(LDFLAGS)

pnm2png: pnm2png.o $(OBJS)
	$(LD) $(CFLAGS) -o $@ $^ $(LDFLAGS)

# RUN

@CSiBE-RUN-RULES@

# --

clean-comp:
	for X in $(PROGS) ; do \
		$(RM) $$X.zipped $$X.comp ; \
	done

clean: clean-comp
	$(RM) *.o $(PROGS)
