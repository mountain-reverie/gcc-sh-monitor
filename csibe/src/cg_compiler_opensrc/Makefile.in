TIME   = @CSiBE-TIME@
SIZE  := @CSiBE-SIZE@
CC     = @CSiBE-CC@
LD     = @CSiBE-CCLD@
AR     = @CSiBE-AR@
CCOPT := @CSiBE-CCOPT@
ZIP   := @CSiBE-ZIP@
VPATH := @CSiBE-SRCDIR@

OBJS=atom.o binding.o cgcmain.o cgstruct.o check.o compile.o constfold.o cpp.o \
     generic_hal.o hal.o inline.o memory.o parser.o printutils.o scanner.o \
     semantic.o stdlib.o support.o support_iter.o symbols.o tokens.o

TOKENIZE_OBJS=atom.o cgstruct.o scanner.o tokenize.o tokens.o

PROGS=cgc tokenize

CFLAGS := $(CCOPT) -w

all:

.c.o:
	I=@CSiBE-OBJCOUNTER@ ; \
	while [ $$((I--)) -gt 0 ] ; do \
		$(CC) $(CFLAGS) -o $@ $< ; \
	done

objs: $(OBJS) tokenize.o

prgs: $(PROGS)

comp: $(PROGS)
	for X in $^ ; do \
		$(ZIP) <$$X >$$X.zipped ; \
		ls -l $$X.zipped >$$X.comp ; \
	done

# PRGS

cgc: $(OBJS)
	$(LD) -o $@ $^

tokenize: $(TOKENIZE_OBJS)
	$(LD) -o $@ $^

# RUN

@CSiBE-RUN-RULES@

# --

clean-comp:
	for X in $(PROGS) ; do \
		rm -f $$X.zipped $$X.comp ; \
	done

clean: clean-comp
	rm -f  $(OBJS) tokenize.o $(PROGS)
